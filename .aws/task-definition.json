{
  "family": "default-haqq-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "2048",
  "memory": "10240",
  "executionRoleArn": "arn:aws:iam::271376211737:role/service-role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "Main",
      "image": "PLACEHOLDER",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "GROQ_MODEL",
          "value": "llama-3.3-70b-versatile"
        }
      ],
      "secrets": [
        {
          "name": "GROQ_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:271376211737:secret:haqq-backend-QwOzFd:GROQ_API_KEY::"
        },
        {
          "name": "GROQ_API_KEY_1",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:271376211737:secret:haqq-backend-QwOzFd:GROQ_API_KEY_1::"
        },
        {
          "name": "GROQ_API_KEY_2",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:271376211737:secret:haqq-backend-QwOzFd:GROQ_API_KEY_2::"
        },
        {
          "name": "GROQ_API_KEY_3",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:271376211737:secret:haqq-backend-QwOzFd:GROQ_API_KEY_3::"
        },
        {
          "name": "NEWSDATA_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:271376211737:secret:haqq-backend-QwOzFd:NEWSDATA_API_KEY::"
        },
        {
          "name": "GNEWS_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:271376211737:secret:haqq-backend-QwOzFd:GNEWS_API_KEY::"
        },
        {
          "name": "CURRENTS_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:271376211737:secret:haqq-backend-QwOzFd:CURRENTS_API_KEY::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/aws/ecs/default/haqq-backend-6edb",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -f http://localhost:8000/health || exit 1"
        ],
        "interval": 30,
        "timeout": 10,
        "retries": 5,
        "startPeriod": 120
      }
    }
  ]
}